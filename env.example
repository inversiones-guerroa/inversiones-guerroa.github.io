# Configuración del servidor
PORT=3000
NODE_ENV=development

# Configuración de JWT y Sesiones (CAMBIAR EN PRODUCCIÓN)
JWT_SECRET=tu-jwt-secret-super-seguro-aqui-cambiar-en-produccion
SESSION_SECRET=tu-session-secret-super-seguro-aqui-cambiar-en-produccion

# Configuración de Supabase (OBTENER DE TU PROYECTO SUPABASE)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-clave-anonima-de-supabase

# Configuración de administrador por defecto
ADMIN_EMAIL=admin@guerroa.com
ADMIN_PASSWORD=admin123

# Configuración de email (CAMBIAR CREDENCIALES)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-contraseña-de-aplicacion
EMAIL_FROM=noreply@guerroa.com

# Configuración de seguridad
FRONTEND_URL=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configuración de archivos
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Configuración de logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log